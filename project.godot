; Engine configuration file.
; It's best edited using the editor UI and not directly,
; but you can always edit it using text editors.

config_version=5

[application]

config/name="Pixel Werewolf"
config/description="A cozy pixel-art social deduction game"
config/features=PackedStringArray("4.2", "GL Compatibility")
run/main_scene="res://scenes/main.tscn"

[autoload]

TestHarness="*res://scripts/test_harness.gd"
GameState="*res://scripts/game_state.gd"

[display]

window/size/viewport_width=480
window/size/viewport_height=270
window/size/window_width_override=1440
window/size/window_height_override=810
window/stretch/mode="canvas_items"
window/stretch/aspect="keep"

[rendering]

textures/canvas_textures/default_texture_filter=0
renderer/rendering_method="gl_compatibility"
renderer/rendering_method.mobile="gl_compatibility"
